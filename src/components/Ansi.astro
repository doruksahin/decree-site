---
/**
 * Renders a REAL captured decree terminal output (.ansi file) in an Expressive
 * Code terminal frame, with the ANSI escape codes interpreted as color.
 *
 * The .ansi files under src/captures/ are generated by scripts/capture.sh from
 * actual `decree` runs — never hand-edited. See docs/plans design §4.
 *
 * Usage:  <Ansi name="snippets/why-hit" title="why a governed file" />
 *         <Ansi name="01-why" />
 */
import { Code } from '@astrojs/starlight/components';

interface Props {
  /** path under src/captures without extension, e.g. "snippets/why-hit" */
  name: string;
  /** terminal titlebar text; defaults to a bare prompt */
  title?: string;
  /** override the frame; "terminal" (default) | "none" */
  frame?: 'terminal' | 'none';
}

const { name, title, frame = 'terminal' } = Astro.props;

const captures = import.meta.glob('/src/captures/**/*.ansi', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const key = `/src/captures/${name}.ansi`;
const code = captures[key];
if (code == null) {
  throw new Error(
    `<Ansi name="${name}"> — no capture at ${key}. Available: ${Object.keys(captures).join(', ')}`,
  );
}
---

<Code code={code} lang="ansi" title={title} frame={frame} />
